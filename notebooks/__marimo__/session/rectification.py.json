      "outputs": [
        {
          "type": "data",
          "data": {
            "text/markdown": "<span class=\"markdown prose dark:prose-invert contents\"><h1 id=\"rectification-of-a-skew-semistandard-tableau\">Rectification of a skew semistandard tableau</h1>\n<span class=\"paragraph\">English notation is used: rows increase downward and columns increase to\nthe right. Ordinary Young diagrams are top-left justified.</span>\n<span class=\"paragraph\">The initial tableau is a word placed on a southwest--northeast diagonal of\ngrid cells, so consecutive cells touch only at corners. This is a skew\nYoung diagram. At every stage, the filled boxes remain a skew\nsemistandard tableau; during a slide, the extra empty square is shown as\nthe current hole.</span></span>"
          }
        }
      ],
      "console": []
    },
